Package: blockr.session
Title: Session Management for 'blockr'
Version: 0.1.0
Authors@R:
    c(person(given = "Nicolas",
             family = "Bennett",
             role = c("aut", "cre"),
             email = "nicolas@cynkra.com"),
      person(given = "Christoph",
